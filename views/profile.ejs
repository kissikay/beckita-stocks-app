<%- include('partials/header') %>

<div class="profile-section">
    <div class="mb-5">
        <h1 class="gradient-text">Your Profile</h1>
        <p class="text-muted">Manage your personal information and avatar.</p>
    </div>

    <div class="glass p-5" style="max-width: 800px; margin: 0 auto; border-radius: 32px;">
        <div class="d-flex flex-column align-items-center mb-5">
            <div class="avatar-container mb-4" style="position: relative;">
                <img id="profilePreview" src="<%= user.profileImage || 'https://via.placeholder.com/150' %>" 
                     style="width: 150px; height: 150px; border-radius: 50%; object-fit: cover; border: 4px solid var(--primary); box-shadow: var(--shadow-lg);">
                <label for="profileInput" class="glass" style="position: absolute; bottom: 0; right: 0; padding: 0.5rem; border-radius: 50%; cursor: pointer; border: 1px solid var(--glass-border);">
                    📷
                </label>
                <input type="file" id="profileInput" style="display: none;" accept="image/*" onchange="previewImage(this)">
            </div>
            <h2 id="dispName"><%= user.fullName %></h2>
            <span class="badge badge-success"><%= user.role.replace('_', ' ').toUpperCase() %></span>
        </div>

        <form id="profileForm" class="mt-4">
            <div class="mb-4">
                <label class="text-muted mb-2 d-block">Full Name</label>
                <input type="text" id="profFullName" value="<%= user.fullName %>" 
                       style="width: 100%; padding: 1.25rem; background: rgba(255,255,255,0.05); border: 1px solid var(--glass-border); border-radius: 14px; color: white;">
            </div>
            <div class="mb-5">
                <label class="text-muted mb-2 d-block">Email Address</label>
                <input type="email" id="profEmail" value="<%= user.email %>" 
                       style="width: 100%; padding: 1.25rem; background: rgba(255,255,255,0.05); border: 1px solid var(--glass-border); border-radius: 14px; color: white;">
            </div>
            <button type="submit" class="btn-primary w-100 p-3">Update Profile Details</button>
        </form>
    </div>
</div>

<script>
function previewImage(input) {
    if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = function(e) {
            document.getElementById('profilePreview').src = e.target.result;
        }
        reader.readAsDataURL(input.files[0]);
    }
}

document.getElementById('profileForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData();
    formData.append('fullName', document.getElementById('profFullName').value);
    formData.append('email', document.getElementById('profEmail').value);
    
    const fileInput = document.getElementById('profileInput');
    if (fileInput.files[0]) {
        formData.append('profileImage', fileInput.files[0]);
    }

    try {
        const btn = e.target.querySelector('button');
        btn.textContent = 'Saving Changes...';
        btn.disabled = true;

        const res = await fetch('/api/admin/profile', {
            method: 'PUT',
            body: formData
        });

        const data = await res.json();
        if (res.ok) {
            alert('Profile updated successfully!');
            document.getElementById('dispName').textContent = data.user.fullName;
            if (data.user.profileImage) {
                document.getElementById('profilePreview').src = data.user.profileImage;
            }
        } else {
            alert(data.error);
        }
    } catch (err) {
        console.error(err);
        alert('Failed to update profile');
    } finally {
        const btn = e.target.querySelector('button');
        btn.textContent = 'Update Profile Details';
        btn.disabled = false;
    }
});
</script>

<%- include('partials/footer') %>
