<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - StockPro</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        body {
            display: flex;
            align-items: center;
            justify-content: center;
            background: radial-gradient(circle at center, #1e1b4b 0%, #0a0b10 100%);
        }
        .login-card {
            width: 400px;
            padding: 3rem;
            text-align: center;
        }
        .login-card h2 {
            margin-bottom: 2rem;
            background: linear-gradient(to right, var(--primary), var(--secondary));
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        input {
            width: 100%;
            margin-bottom: 1.5rem;
            padding: 1.2rem;
            border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.1);
            background: rgba(255,255,255,0.1);
            color: white;
            font-size: 1rem;
            outline: none;
            transition: all 0.3s ease;
        }
        input:focus {
            background: rgba(255,255,255,0.15);
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.2);
        }
        input::placeholder {
            color: rgba(255,255,255,0.5);
        }
        button {
            width: 100%;
            padding: 1rem;
            border-radius: 12px;
            border: none;
            background: linear-gradient(to right, var(--primary), var(--secondary));
            color: white;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s;
        }
        button:hover {
            transform: scale(1.02);
        }
    </style>
</head>
<body>
    <div class="login-card glass shadow-vibrant">
        <div id="loginFormArea">
            <h2>StockPro Login</h2>
            <form id="loginForm">
                <input type="email" id="email" placeholder="Manager Email" required>
                <input type="password" id="password" placeholder="Password" required>
                <button type="submit">Enter Dashboard</button>
            </form>
            <p class="text-muted mt-4" style="font-size: 0.9rem;">Need an account? <a href="/register" style="color: var(--accent-blue); text-decoration: none; font-weight: 600;">Register here</a></p>
        </div>

        <div id="waitingUI" style="display: none;">
            <div style="font-size: 3rem; margin-bottom: 1.5rem;">⏳</div>
            <h2 class="gradient-text">Pending Approval</h2>
            <p id="statusMsg" class="text-muted mb-5" style="font-size: 1.1rem; line-height: 1.6;">Your account is currently under review by the Super Admin.</p>
            <div class="p-4 glass mb-4" style="border-radius: 16px;">
                <p class="text-muted" style="font-size: 0.9rem;">Access will be granted once Kissi Stanley Kofi approves your registration.</p>
            </div>
            <button onclick="checkStatus()" class="btn-primary w-100">Check Status Again</button>
        </div>
    </div>
    <script src="/js/auth.js"></script>
</body>
</html>
