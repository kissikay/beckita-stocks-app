<%- include('partials/header') %>

<div class="inventory-section">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="gradient-text">Inventory Management</h1>
            <p class="text-muted" style="font-size: 1.1rem;">Monitor your products, categories, and stock levels effortlessly.</p>
        </div>
        <button class="btn-primary p-3 shadow-vibrant" onclick="openAddModal()">+ Add New Product</button>
    </div>

    <div class="glass p-4 overflow-hidden">
        <div class="table-container">
            <table class="inventory-table w-100">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Product Name</th>
                        <th>Category</th>
                        <th>Stock</th>
                        <th>Price</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="inventoryBody">
                    <!-- Data will be loaded dynamically -->
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modals Container -->
<div id="modalOverlay" class="modal-overlay" style="display:none;" onclick="closeAllModals()"></div>

<!-- Add Product Modal -->
<div id="addProductModal" class="modal glass shadow-vibrant" style="display:none;">
    <div class="modal-header mb-4">
        <h3>Add New Product</h3>
        <p class="text-muted">Enter product details to add to inventory.</p>
    </div>
    <form id="addProductForm" onsubmit="confirmAdd(event)">
        <input type="text" id="p_id" placeholder="Product ID (e.g. HF-120)" required>
        <input type="text" id="p_name" placeholder="Product Name" required>
        <input type="text" id="p_category" placeholder="Category" required>
        <div class="d-flex gap-2">
            <input type="number" id="p_price" placeholder="Selling Price" step="0.01" required>
            <input type="number" id="p_cost" placeholder="Cost Price" step="0.01" required>
        </div>
        <div class="d-flex gap-2">
            <input type="number" id="p_stock" placeholder="Initial Stock" required>
            <input type="number" id="p_min" placeholder="Min Stock Level" required>
        </div>
        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn-primary flex-grow-1 p-3">Create Product</button>
            <button type="button" class="btn-outline glass p-3" onclick="closeAllModals()">Cancel</button>
        </div>
    </form>
</div>

<!-- Edit Product Modal -->
<div id="editProductModal" class="modal glass shadow-vibrant" style="display:none;">
    <div class="modal-header mb-4">
        <h3>Edit Product</h3>
        <p class="text-muted">Update product details.</p>
    </div>
    <form id="editProductForm" onsubmit="confirmEdit(event)">
        <input type="hidden" id="edit_p_object_id">
        <input type="text" id="edit_p_id" placeholder="Product ID (e.g. HF-120)" required>
        <input type="text" id="edit_p_name" placeholder="Product Name" required>
        <input type="text" id="edit_p_category" placeholder="Category" required>
        <div class="d-flex gap-2">
            <input type="number" id="edit_p_price" placeholder="Selling Price" step="0.01" required>
            <input type="number" id="edit_p_cost" placeholder="Cost Price" step="0.01" required>
        </div>
        <div class="d-flex gap-2">
            <input type="number" id="edit_p_stock" placeholder="Stock Level" required>
            <input type="number" id="edit_p_min" placeholder="Min Stock Level" required>
        </div>
        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn-primary flex-grow-1 p-3">Update Product</button>
            <button type="button" class="btn-outline glass p-3" onclick="closeAllModals()">Cancel</button>
        </div>
    </form>
</div>

<!-- Restock Modal -->
<div id="restockModal" class="modal glass shadow-vibrant-purple" style="display:none;">
    <div class="modal-header mb-4">
        <h3>Restock Product</h3>
        <p class="text-muted">Add more units to current inventory.</p>
    </div>
    <form id="restockForm" onsubmit="confirmRestock(event)">
        <input type="hidden" id="restockId">
        <label class="text-muted mb-2 d-block">Quantity to add:</label>
        <input type="number" id="restockAmount" placeholder="e.g. 50" required>
        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn-primary flex-grow-1 p-3">Update Stock</button>
            <button type="button" class="btn-outline glass p-3" onclick="closeAllModals()">Cancel</button>
        </div>
    </form>
</div>

<%- include('partials/footer') %>
